<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Product"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fill in the details below to list your item"
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="32dp" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PRODUCT TITLE"
            android:textSize="11sp"
            android:textColor="@color/label_color"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            style="@style/DarkOutlinedField">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="e.g. Nike Air Max"
                android:inputType="textCapSentences"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/hint_color"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Short Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SHORT DESCRIPTION"
            android:textSize="11sp"
            android:textColor="@color/label_color"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            style="@style/DarkOutlinedField">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etShortDescription"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="e.g. Brand new, unused, great condition"
                android:inputType="textCapSentences"
                android:maxLength="60"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/hint_color"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DESCRIPTION"
            android:textSize="11sp"
            android:textColor="@color/label_color"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            style="@style/DarkOutlinedField">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Describe your product..."
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/hint_color"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Price -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PRICE (₹)"
            android:textSize="11sp"
            android:textColor="@color/label_color"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            style="@style/DarkOutlinedField">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/hint_color"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Your Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="YOUR NAME"
            android:textSize="11sp"
            android:textColor="@color/label_color"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            style="@style/DarkOutlinedField">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUploaderName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="John Doe"
                android:inputType="textPersonName"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/hint_color"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Contact -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONTACT NUMBER"
            android:textSize="11sp"
            android:textColor="@color/label_color"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            style="@style/DarkOutlinedField">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUploaderContact"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="+91 00000 00000"
                android:inputType="phone"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/hint_color"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Select Images Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectImages"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Select Images (Min 3)"
            android:textSize="14sp"
            android:textColor="@color/text_soft_purple"
            app:backgroundTint="@color/field_bg"
            app:strokeColor="@color/accent_purple"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            app:elevation="0dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvImageCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 image(s) selected"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="10dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSelectedImages"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_marginBottom="24dp" />

        <!-- Upload Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpload"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Upload Product"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:letterSpacing="0.02"
            app:backgroundTint="@color/accent_purple"
            app:cornerRadius="10dp"
            app:elevation="0dp"
            android:layout_marginBottom="16dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/accent_purple"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>