<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:paddingTop="40dp"
    android:background="@color/surface_dark">

    <!-- Task 2: Profile photo — loaded from Google account via Glide -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/profileImage"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_default_avtar"
        android:layout_marginBottom="14dp" />

    <!-- Task 2: User's real name from Firestore -->
    <TextView
        android:id="@+id/profileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <!-- Task 2: User's email — replaces static "SnapShop member" -->
    <TextView
        android:id="@+id/profileEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="your@email.com"
        android:textSize="13sp"
        android:textColor="@color/text_muted"
        android:layout_marginTop="2dp" />

    <!-- "SnapShop member" badge kept below email -->
    <TextView
        android:id="@+id/profileAbout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SnapShop member"
        android:textSize="11sp"
        android:textColor="@color/text_muted"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="20dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/logoutButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Logout"
        android:textSize="13sp"
        android:textColor="#FF8A65"
        app:backgroundTint="@color/field_bg"
        app:strokeColor="#FF8A65"
        app:strokeWidth="1dp"
        app:cornerRadius="8dp"
        app:elevation="0dp" />

</LinearLayout>